{
  "loop_id": "async_example_loop",
  "objective": "Raise fake score to 0.70 with async callback collection",
  "repo_path": "/tmp/calo-async-example-loop",
  "target_metric": "score",
  "target_value": 0.7,
  "branch": "agent-loop/main",
  "execution_mode": "async",
  "iteration_limits": {
    "max_turns": 3,
    "patience": 3,
    "min_delta": 0.001
  },
  "commands": {
    "validation": "python -m py_compile target_app.py",
    "train": "python fake_train.py --callback-file {callback_file} --run-id {run_id} --turn-id {turn_id}"
  },
  "human_gate": {
    "diff_review": false,
    "destructive_actions": true,
    "auto_commit": true
  }
}
